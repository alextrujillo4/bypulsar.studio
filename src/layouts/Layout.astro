---
import "../styles/globals.css";
import { brand, tracking } from "../config";
import { dict, DEFAULT_LOCALE } from "../i18n/dict";
import IntroOverlay from "../components/IntroOverlay.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import CursorGlow from "../components/CursorGlow.astro";

// Inline the translations dict so the runtime script can read it
// without an extra fetch.
const dictJson = JSON.stringify(dict);

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${brand.name} — ${brand.tagline}`,
  description = brand.description,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, brand.url).toString();
---

<!doctype html>
<html lang="es" class="bg-bg text-fg antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={brand.name} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Inline pre-paint style — guarantees pure black body before any
        external CSS or stale cache has a chance to render light. */}
    <style is:inline>html,body{background:#000!important;color:#f5f5f5}</style>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
    />

    <script is:inline>
      // Skip intro on subsequent pageloads in the same tab.
      try {
        if (sessionStorage.getItem("pulsar-intro-seen")) {
          document.documentElement.classList.add("intro-skip");
        } else {
          sessionStorage.setItem("pulsar-intro-seen", "1");
        }
      } catch (_) {
        document.documentElement.classList.add("intro-skip");
      }
    </script>

    {/* i18n runtime — reads localStorage, swaps every [data-i18n] /
        [data-i18n-html] / [data-i18n-attr-*] node when the language
        changes. SSR ships EN; if the saved locale is non-EN, the
        applyLocale() call after DOMContentLoaded swaps text. Exposes
        window.__pulsarSetLocale(code) for the LanguageSwitcher. */}
    <script is:inline define:vars={{ dictJson, defaultLocale: DEFAULT_LOCALE }}>
      (function () {
        const DICT = JSON.parse(dictJson);
        const KEY = "pulsar.lang";

        function getSaved() {
          try {
            const v = localStorage.getItem(KEY);
            if (v && DICT[v]) return v;
          } catch (_) {}
          return defaultLocale;
        }

        function applyLocale(locale) {
          const d = DICT[locale] || DICT[defaultLocale];
          // Plain text translations
          document.querySelectorAll("[data-i18n]").forEach((el) => {
            const key = el.getAttribute("data-i18n");
            if (key && d[key] !== undefined) el.textContent = d[key];
          });
          // HTML translations (preserves inline markup like <span>)
          document.querySelectorAll("[data-i18n-html]").forEach((el) => {
            const key = el.getAttribute("data-i18n-html");
            if (key && d[key] !== undefined) el.innerHTML = d[key];
          });
          // Attribute translations: data-i18n-attr-{name}="key"
          document.querySelectorAll("*").forEach((el) => {
            for (const attr of Array.from(el.attributes)) {
              if (!attr.name.startsWith("data-i18n-attr-")) continue;
              const name = attr.name.slice("data-i18n-attr-".length);
              const key = attr.value;
              if (d[key] !== undefined) el.setAttribute(name, d[key]);
            }
          });
          document.documentElement.lang = locale;
          try { localStorage.setItem(KEY, locale); } catch (_) {}
          document.dispatchEvent(
            new CustomEvent("pulsar:locale-changed", { detail: { locale } })
          );
        }

        // Public API for LanguageSwitcher
        window.__pulsarSetLocale = applyLocale;

        const initial = getSaved();
        // First pass: apply right after DOM is ready so we replace
        // SSR text before the user sees a flicker.
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", () => applyLocale(initial));
        } else {
          applyLocale(initial);
        }
      })();
    </script>
  </head>

  <body class="bg-bg text-fg font-sans selection:bg-fg selection:text-bg">
    <IntroOverlay />
    <CursorGlow />
    <slot />
    <ConsentBanner />

    <script>
      import Lenis from "lenis";
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reduced) {
        const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Smooth-scroll anchor links (header nav, overlay nav, footer
        // links) to their target sections. Without this, anchors do
        // a native instant jump even when Lenis is active for wheel.
        // Offset accounts for the sticky header (~80px) so the target
        // section's top doesn't get hidden behind it.
        document.addEventListener("click", (e) => {
          const t = e.target as HTMLElement;
          const link = t.closest('a[href^="#"]') as HTMLAnchorElement | null;
          if (!link) return;
          const href = link.getAttribute("href");
          if (!href || href === "#") return;
          const dest = document.querySelector(href);
          if (!dest) return;
          e.preventDefault();
          lenis.scrollTo(dest as HTMLElement, {
            offset: -80,
            duration: 1.2,
          });
          // Update the URL hash without triggering a jump
          history.pushState(null, "", href);
        });
      }
    </script>

    {/* TODO: GA4 — replace with measurement ID when available */}
    {tracking.ga4Id && (
      <>
        <script
          is:inline
          data-consent-gated
          type="text/plain"
          src={`https://www.googletagmanager.com/gtag/js?id=${tracking.ga4Id}`}
        ></script>
        <script is:inline data-consent-gated type="text/plain" set:html={`
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', '${tracking.ga4Id}');
        `}></script>
      </>
    )}

    {/* TODO: Microsoft Clarity — replace with project ID when available */}
    {tracking.clarityId && (
      <script is:inline data-consent-gated type="text/plain" set:html={`
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "${tracking.clarityId}");
      `}></script>
    )}
  </body>
</html>

