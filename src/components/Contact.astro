---
import { social, cadence } from "../config";
---

<section id="contact" class="border-t border-line">
  <div class="mx-auto max-w-[1440px] px-6 md:px-10 lg:px-16 py-24 md:py-40">
    <p class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-12">
      04 / Contact
    </p>

    <h2 class="font-display font-extrabold tracking-tightest leading-[0.95] text-[clamp(48px,9vw,140px)] max-w-5xl mb-16">
      Construyamos
      <br />
      <span class="italic font-light">contigo.</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
      <div>
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-4">
          Email
        </p>
        <a
          href={`mailto:${social.email}`}
          class="font-display font-semibold text-2xl md:text-4xl tracking-tight hover:text-muted transition-colors duration-200 break-all"
        >
          {social.email}
        </a>
      </div>

      <div>
        <p class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-4">
          Agenda una llamada
        </p>
        <a
          href={social.calendly}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full bg-fg text-bg px-6 py-3 text-sm font-medium hover:bg-muted transition-colors duration-200"
        >
          Discovery call
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <div class="mt-20 pt-10 border-t border-line grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
      <a
        href={social.instagram}
        target="_blank"
        rel="noopener"
        class="text-muted hover:text-fg transition-colors duration-200 inline-flex items-center gap-2"
      >
        Instagram
        <span aria-hidden="true">↗</span>
      </a>
      <a
        href={cadence.url}
        target="_blank"
        rel="noopener"
        class="text-muted hover:text-fg transition-colors duration-200 inline-flex items-center gap-2"
      >
        Cadence — el SaaS
        <span aria-hidden="true">↗</span>
      </a>
      <p class="text-muted">Madrid · España</p>
    </div>
  </div>
</section>
