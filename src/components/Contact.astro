---
import { social, cadence } from "../config";
---

<section id="contact" class="ds-section">
  <div class="ds-section-inner">
    <p class="ds-label mb-12">contact.</p>

    <h2 class="ds-heading-section max-w-6xl mb-16">
      construyamos
      <br />
      <span class="ds-italic">contigo.</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
      <div>
        <p class="ds-label mb-4">Email</p>
        <a
          href={`mailto:${social.email}`}
          class="ds-heading-sub hover:text-muted transition-colors duration-200 break-all underline decoration-1 underline-offset-8"
        >
          + {social.email}
        </a>
      </div>

      <div>
        <p class="ds-label mb-4">Agenda una llamada</p>
        <a href={social.calendly} target="_blank" rel="noopener" class="ds-btn-primary">
          Discovery call
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <div class="mt-20 pt-10 border-t border-line grid grid-cols-1 md:grid-cols-3 gap-8 text-sm">
      <a href={social.instagram} target="_blank" rel="noopener" class="ds-link-external">
        Instagram <span aria-hidden="true">↗</span>
      </a>
      <a href={cadence.url} target="_blank" rel="noopener" class="ds-link-external">
        Cadence — el SaaS <span aria-hidden="true">↗</span>
      </a>
      <p class="text-muted">Madrid · España</p>
    </div>
  </div>
</section>
