---
import { brand, nav, social } from "../config";
---

<header class="header" data-reveal style="--reveal-delay: 0.1s">
  <div class="ds-container">
    <div class="header-bar">
      <a href="/" class="ds-logo text-base md:text-lg" aria-label={brand.name}>
        {brand.shortName.toLowerCase()}
      </a>

      {/* Desktop nav — distributed inline. Hidden on mobile (hamburger
          handles it). */}
      <nav class="header-nav" aria-label="Sections">
        {nav.map((item) => (
          <a href={item.href} class="header-nav-link">{item.label}</a>
        ))}
      </nav>

      <button
        type="button"
        class="header-burger"
        aria-label="Open menu"
        aria-controls="nav-overlay"
        aria-expanded="false"
        data-burger
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

{/* Full-screen menu overlay */}
<div id="nav-overlay" class="nav-overlay" hidden>
  <div class="nav-overlay-bar ds-container">
    <a href="/" class="ds-logo text-base md:text-lg">
      {brand.shortName.toLowerCase()}
    </a>
    <button
      type="button"
      class="header-burger header-burger--open"
      aria-label="Close menu"
      data-burger-close
    >
      <span></span>
      <span></span>
    </button>
  </div>

  <nav class="nav-overlay-list" aria-label="Main navigation">
    <ul>
      <li><a href="/" data-nav-close>home</a></li>
      {nav.map((item) => (
        <li>
          <a href={item.href} data-nav-close>{item.label.toLowerCase()}</a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="nav-overlay-foot ds-container">
    <a href={`mailto:${social.email}`} class="nav-overlay-email">
      <span aria-hidden="true">+</span> {social.email}
    </a>
    <p class="nav-overlay-copy">© {new Date().getFullYear()} {brand.name}</p>
  </div>
</div>

<style>
  .header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(10, 10, 10, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
    color: #f5f5f5;
    gap: 1.5rem;
  }

  /* Desktop nav — distributed in the middle of the bar, hidden on
     mobile (hamburger overlay takes over). */
  .header-nav {
    display: none;
    flex: 1;
    align-items: center;
    justify-content: space-evenly;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .header-nav {
      display: flex;
    }
  }

  .header-nav-link {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: #f5f5f5;
    text-decoration: none;
    transition: color 0.2s ease, opacity 0.2s ease;
    opacity: 0.85;
  }

  .header-nav-link:hover {
    opacity: 1;
    color: #ffffff;
  }

  .header-burger {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0;
  }

  .header-burger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.2s ease;
    margin: 0 auto;
  }

  .header-burger--open span:first-child {
    transform: translateY(2.75px) rotate(45deg);
  }
  .header-burger--open span:last-child {
    transform: translateY(-2.75px) rotate(-45deg);
  }

  /* ─── Overlay ──────────────────────────────────────────── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: #0a0a0a;
    color: #f5f5f5;
    display: flex;
    flex-direction: column;
    animation: nav-in 0.4s ease-out;
  }

  .nav-overlay[hidden] {
    display: none;
  }

  .nav-overlay-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #1f1f1f;
  }

  .nav-overlay-list {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-overlay-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-overlay-list a {
    display: inline-block;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(32px, 5vw, 64px);
    letter-spacing: -0.04em;
    line-height: 1.1;
    color: #f5f5f5;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-overlay-list a:hover {
    color: #9a9a9a;
  }

  .nav-overlay-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 2rem;
    padding-bottom: 2.5rem;
    border-top: 1px solid #1f1f1f;
  }

  .nav-overlay-email {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(16px, 1.8vw, 22px);
    color: #f5f5f5;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 6px;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .nav-overlay-copy {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #9a9a9a;
    margin: 0;
  }

  @keyframes nav-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>

<script is:inline>
  (function () {
    const overlay = document.getElementById("nav-overlay");
    const burgers = document.querySelectorAll("[data-burger]");
    const closeBtns = document.querySelectorAll("[data-burger-close]");
    const links = document.querySelectorAll("[data-nav-close]");

    function open() {
      if (!overlay) return;
      overlay.hidden = false;
      document.body.style.overflow = "hidden";
      burgers.forEach((b) => b.setAttribute("aria-expanded", "true"));
    }

    function close() {
      if (!overlay) return;
      overlay.hidden = true;
      document.body.style.overflow = "";
      burgers.forEach((b) => b.setAttribute("aria-expanded", "false"));
    }

    burgers.forEach((b) => b.addEventListener("click", open));
    closeBtns.forEach((b) => b.addEventListener("click", close));
    links.forEach((l) => l.addEventListener("click", close));

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && overlay && !overlay.hidden) close();
    });
  })();
</script>
