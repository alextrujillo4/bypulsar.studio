---
import { brand, nav, social } from "../config";
---

<header class="ds-header" data-reveal style="--reveal-delay: 0.1s">
  <div class="ds-container">
    <div class="flex items-center justify-between py-6">
      <a href="/" class="ds-logo text-lg" aria-label={brand.name}>
        {brand.shortName.toUpperCase()}
      </a>

      <nav class="hidden md:flex items-center gap-8 text-sm">
        {nav.map((item) => (
          <a href={item.href} class="ds-link">{item.label}</a>
        ))}
      </nav>

      <a
        href={social.calendly}
        target="_blank"
        rel="noopener"
        class="ds-btn-pill hidden sm:inline-flex"
      >
        Discovery call
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>
