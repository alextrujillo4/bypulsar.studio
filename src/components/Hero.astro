---
import { brand, social } from "../config";
---

<section class="hero">
  <div class="ds-container pt-20 md:pt-32 pb-24 md:pb-40">
    <p class="ds-label mb-10" data-reveal style="--reveal-delay: 0s">
      {brand.shortName} Studio · {brand.city}
    </p>

    <h1 class="ds-heading-hero" data-reveal style="--reveal-delay: 0.15s">
      Diseño y código
      <br />
      para marcas que
      <br />
      <span class="ds-italic">mueven cuerpos.</span>
    </h1>

    <p class="ds-body mt-10 max-w-2xl" data-reveal style="--reveal-delay: 0.35s">
      Estudio digital boutique para comunidades wellness — running, yoga, gym,
      padel y outdoor. Branding, web, apps y un SaaS propio.
    </p>

    <div class="mt-12 flex flex-wrap items-center gap-3" data-reveal style="--reveal-delay: 0.5s">
      <a href={social.calendly} target="_blank" rel="noopener" class="ds-btn-primary">
        Discovery call
        <span aria-hidden="true">→</span>
      </a>
      <a href="#studio" class="ds-btn-ghost">Conoce el estudio</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
  }
</style>
