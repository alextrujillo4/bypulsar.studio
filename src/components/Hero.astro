---
import { brand, social } from "../config";
---

<section class="hero">
  <div class="mx-auto max-w-[1440px] px-6 md:px-10 lg:px-16 pt-20 md:pt-32 pb-24 md:pb-40">
    <p
      class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-10"
      data-reveal
      style="--reveal-delay: 0s"
    >
      {brand.shortName} Studio · {brand.city}
    </p>

    <h1
      class="font-display font-extrabold tracking-tightest leading-[0.95] text-fg text-[clamp(56px,11vw,160px)]"
      data-reveal
      style="--reveal-delay: 0.15s"
    >
      Diseño y código
      <br />
      para marcas que
      <br />
      <span class="italic font-light">mueven cuerpos.</span>
    </h1>

    <p
      class="mt-10 max-w-2xl text-base md:text-lg text-muted leading-relaxed"
      data-reveal
      style="--reveal-delay: 0.35s"
    >
      Estudio digital boutique para comunidades wellness — running, yoga, gym,
      padel y outdoor. Branding, web, apps y un SaaS propio.
    </p>

    <div
      class="mt-12 flex flex-wrap items-center gap-3"
      data-reveal
      style="--reveal-delay: 0.5s"
    >
      <a
        href={social.calendly}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 rounded-full bg-fg text-bg px-6 py-3 text-sm font-medium hover:bg-muted transition-colors duration-200"
      >
        Discovery call
        <span aria-hidden="true">→</span>
      </a>
      <a
        href="#studio"
        class="inline-flex items-center gap-2 rounded-full border border-line px-6 py-3 text-sm hover:bg-card transition-colors duration-200"
      >
        Conoce el estudio
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
  }
</style>
