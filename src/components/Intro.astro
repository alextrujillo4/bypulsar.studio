---
import { brand, social } from "../config";
---

<section id="intro" class="intro-section">
  {/* Faded "pulsar" watermark behind the text */}
  <span class="intro-watermark" aria-hidden="true">{brand.shortName.toLowerCase()}</span>

  <div class="intro-inner">
    <p class="intro-text">
      <span class="intro-bright">We're {brand.shortName}.</span>{" "}
      <span class="intro-fade">{brand.tagline}</span>
    </p>

    <p class="intro-sub">
      One signal, two operators. Design and code for the{" "}
      <span class="intro-emph">clubs</span>,{" "}
      <span class="intro-emph">gyms</span> and{" "}
      <span class="intro-emph">communities</span> that move.
    </p>

    <a href={social.calendly} target="_blank" rel="noopener" class="intro-cta">
      Book a call
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .intro-section {
    position: relative;
    overflow: hidden;
    padding: clamp(6rem, 14vw, 12rem) 1.5rem;
    text-align: center;
  }

  .intro-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(220px, 38vw, 540px);
    letter-spacing: -0.06em;
    color: rgba(245, 245, 245, 0.045);
    text-transform: lowercase;
    pointer-events: none;
    user-select: none;
    line-height: 0.85;
    white-space: nowrap;
  }

  .intro-inner {
    position: relative;
    z-index: 1;
    max-width: 56rem;
    margin: 0 auto;
  }

  .intro-text {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(28px, 4.5vw, 56px);
    letter-spacing: -0.03em;
    line-height: 1.15;
  }

  .intro-bright {
    color: #f5f5f5;
  }

  .intro-fade {
    color: #6a6a6a;
  }

  .intro-sub {
    margin: 1.75rem auto 2.5rem;
    max-width: 32rem;
    font-size: clamp(14px, 1.1vw, 16px);
    color: #9a9a9a;
    line-height: 1.55;
  }

  /* Highlight key audience nouns inside the description without
     breaking the muted tone of the rest of the sentence. */
  .intro-emph {
    color: #d8d8d8;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 4px;
  }

  .intro-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #f5f5f5;
    color: #0a0a0a;
    border-radius: 999px;
    padding: 0.85rem 1.5rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: transform 0.25s ease, background 0.25s ease;
  }

  .intro-cta:hover {
    transform: translateY(-2px);
    background: #ffffff;
  }
</style>
