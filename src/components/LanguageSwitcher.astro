---
import { LOCALES, DEFAULT_LOCALE } from "../i18n/dict";
---

<div class="lang-switcher" data-lang-switcher>
  <button
    type="button"
    class="lang-trigger"
    aria-haspopup="listbox"
    aria-expanded="false"
    aria-label="Language"
    data-lang-trigger
  >
    <span data-lang-current>{DEFAULT_LOCALE.toUpperCase()}</span>
    <span class="lang-chevron" aria-hidden="true">▾</span>
  </button>

  <ul class="lang-menu" role="listbox" data-lang-menu hidden>
    {LOCALES.map((l) => (
      <li role="option" aria-selected={l.code === DEFAULT_LOCALE}>
        <button
          type="button"
          class="lang-option"
          data-lang-set={l.code}
          data-lang-active={l.code === DEFAULT_LOCALE ? "true" : "false"}
        >
          <span class="lang-abbr">{l.abbr}</span>
          <span class="lang-label">{l.label}</span>
          <span class="lang-tick" aria-hidden="true">●</span>
        </button>
      </li>
    ))}
  </ul>
</div>

<style>
  .lang-switcher {
    position: relative;
    display: inline-flex;
  }

  .lang-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: transparent;
    border: 1px solid rgba(245, 245, 245, 0.18);
    color: #f5f5f5;
    border-radius: 999px;
    padding: 0.45rem 0.8rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .lang-trigger:hover,
  .lang-trigger[aria-expanded="true"] {
    background: rgba(245, 245, 245, 0.06);
    border-color: rgba(245, 245, 245, 0.4);
  }

  .lang-chevron {
    font-size: 10px;
    line-height: 1;
    transition: transform 0.2s ease;
  }

  .lang-trigger[aria-expanded="true"] .lang-chevron {
    transform: rotate(180deg);
  }

  .lang-menu {
    position: absolute;
    top: calc(100% + 0.4rem);
    right: 0;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    min-width: 160px;
    background: #0e0e0e;
    border: 1px solid rgba(245, 245, 245, 0.12);
    border-radius: 14px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
    z-index: 60;
    animation: lang-menu-in 0.15s ease-out;
  }

  .lang-menu[hidden] {
    display: none;
  }

  .lang-option {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    background: transparent;
    border: 0;
    color: #f5f5f5;
    padding: 0.55rem 0.7rem;
    border-radius: 10px;
    font-family: "Inter", system-ui, sans-serif;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.15s ease;
    text-align: left;
  }

  .lang-option:hover {
    background: rgba(245, 245, 245, 0.06);
  }

  .lang-abbr {
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: #9a9a9a;
    width: 22px;
  }

  .lang-label {
    color: #f5f5f5;
  }

  .lang-tick {
    font-size: 8px;
    color: #f5f5f5;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .lang-option[data-lang-active="true"] .lang-tick {
    opacity: 1;
  }

  @keyframes lang-menu-in {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script is:inline>
  (function () {
    const switcher = document.querySelector("[data-lang-switcher]");
    if (!switcher) return;
    const trigger = switcher.querySelector("[data-lang-trigger]");
    const menu = switcher.querySelector("[data-lang-menu]");
    const options = switcher.querySelectorAll("[data-lang-set]");
    const currentLabel = switcher.querySelector("[data-lang-current]");
    if (!trigger || !menu || !currentLabel) return;

    function open() {
      menu.hidden = false;
      trigger.setAttribute("aria-expanded", "true");
    }
    function close() {
      menu.hidden = true;
      trigger.setAttribute("aria-expanded", "false");
    }
    function toggle() {
      if (menu.hidden) open(); else close();
    }

    trigger.addEventListener("click", (e) => { e.stopPropagation(); toggle(); });
    document.addEventListener("click", (e) => {
      if (!switcher.contains(e.target)) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu.hidden) close();
    });

    options.forEach((opt) => {
      opt.addEventListener("click", () => {
        const code = opt.getAttribute("data-lang-set");
        if (!code || !window.__pulsarSetLocale) return;
        window.__pulsarSetLocale(code);
        // Reflect selection in this dropdown
        currentLabel.textContent = code.toUpperCase();
        options.forEach((o) => {
          o.setAttribute(
            "data-lang-active",
            o.getAttribute("data-lang-set") === code ? "true" : "false"
          );
          const li = o.closest("li");
          if (li) {
            li.setAttribute(
              "aria-selected",
              o.getAttribute("data-lang-set") === code ? "true" : "false"
            );
          }
        });
        close();
      });
    });

    // On boot, sync the dropdown's visible label with whatever the
    // global runtime decided (in case it picked up a saved locale).
    document.addEventListener("pulsar:locale-changed", (e) => {
      const code = e.detail && e.detail.locale;
      if (!code) return;
      currentLabel.textContent = String(code).toUpperCase();
      options.forEach((o) => {
        o.setAttribute(
          "data-lang-active",
          o.getAttribute("data-lang-set") === code ? "true" : "false"
        );
      });
    });
  })();
</script>
