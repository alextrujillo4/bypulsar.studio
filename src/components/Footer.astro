---
import { brand, social, cadence } from "../config";
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="ds-section-inner-tight">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <span class="ds-logo text-lg">{brand.shortName.toUpperCase()}</span>
        <span class="text-muted text-sm">
          © {year} {brand.name} · {brand.city}
        </span>
      </div>

      <nav class="flex items-center gap-6 text-sm">
        <a href={cadence.url} target="_blank" rel="noopener" class="ds-link">
          Cadence ↗
        </a>
        <a href={social.instagram} target="_blank" rel="noopener" class="ds-link">
          Instagram ↗
        </a>
        <a href={`mailto:${social.email}`} class="ds-link">Email</a>
      </nav>
    </div>
  </div>
</footer>
