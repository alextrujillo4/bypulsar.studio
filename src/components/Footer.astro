---
import { brand, social, cadence, nav } from "../config";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    {/* Top — 3 columnas: email | navegación | social */}
    <div class="footer-grid-top">
      <div class="footer-contact">
        <a href={`mailto:${social.email}`} class="footer-email">
          <span class="footer-email-mark" aria-hidden="true">+</span>
          {social.email}
        </a>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Navigation</h4>
        <ul>
          <li><a href="/">Home</a></li>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4 class="footer-col-title">Social</h4>
        <ul>
          <li>
            <a href={social.instagram} target="_blank" rel="noopener">
              Instagram <span aria-hidden="true">↗</span>
            </a>
          </li>
          <li>
            <a href={cadence.url} target="_blank" rel="noopener">
              Cadence <span aria-hidden="true">↗</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${social.email}`}>Email</a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom — 1/3 vacío + 2/3 wordmark */}
    <div class="footer-grid-bottom">
      <div aria-hidden="true"></div>
      <div class="footer-mark-wrap">
        <span class="footer-mark" aria-hidden="true">pulsar</span>
        <span class="footer-mark-sub" aria-hidden="true">studio</span>
      </div>
    </div>

    {/* Meta */}
    <div class="footer-meta">
      <p>© {year} {brand.name}</p>
      <p>{brand.city} · Spain</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: #f0f0f0;
    border-top: 1px solid #e5e5e5;
  }

  .footer-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: clamp(3rem, 7vw, 6rem) clamp(1.5rem, 4vw, 4rem) 0;
  }

  /* ─── Top: email + nav + social en 3 cols ────────────── */
  .footer-grid-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  @media (min-width: 768px) {
    .footer-grid-top {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .footer-email {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(20px, 2.4vw, 32px);
    letter-spacing: -0.02em;
    color: #0a0a0a;
    text-decoration: underline;
    text-decoration-thickness: 1.5px;
    text-underline-offset: 6px;
    transition: color 0.2s ease;
    word-break: break-all;
  }

  .footer-email:hover {
    color: #7a7a7a;
  }

  .footer-email-mark {
    font-size: 0.7em;
    text-decoration: none;
  }

  .footer-col-title {
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #7a7a7a;
    margin: 0 0 1rem 0;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-col li {
    margin-bottom: 0.5rem;
  }

  .footer-col a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(15px, 1.3vw, 18px);
    font-weight: 500;
    color: #0a0a0a;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: #7a7a7a;
  }

  /* ─── Bottom: 1/3 vacío + 2/3 wordmark ────────────── */
  .footer-grid-bottom {
    display: grid;
    grid-template-columns: 1fr;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  @media (min-width: 768px) {
    .footer-grid-bottom {
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
    }
  }

  .footer-mark-wrap {
    user-select: none;
  }

  .footer-mark {
    display: block;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(72px, 16vw, 240px);
    letter-spacing: -0.06em;
    line-height: 0.95;
    color: #0a0a0a;
    text-transform: lowercase;
    padding-bottom: 0.12em; /* clearance for the "p" descender */
  }

  .footer-mark-sub {
    display: block;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(24px, 5vw, 70px);
    letter-spacing: -0.04em;
    line-height: 1;
    color: #0a0a0a;
    text-transform: lowercase;
  }

  /* ─── Meta strip ─────────────────────────────────────── */
  .footer-meta {
    border-top: 1px solid #e5e5e5;
    padding: 1.5rem 0 2rem 0;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    font-family: "IBM Plex Sans", system-ui, sans-serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #7a7a7a;
  }

  .footer-meta p {
    margin: 0;
  }
</style>
