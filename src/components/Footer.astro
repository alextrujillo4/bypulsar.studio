---
import { brand, social, cadence } from "../config";
const year = new Date().getFullYear();
---

<footer class="border-t border-line">
  <div class="mx-auto max-w-[1440px] px-6 md:px-10 lg:px-16 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div class="flex items-center gap-4">
        <span class="font-display font-extrabold text-lg tracking-tight">
          {brand.shortName.toUpperCase()}
        </span>
        <span class="text-muted text-sm">
          © {year} {brand.name} · {brand.city}
        </span>
      </div>

      <nav class="flex items-center gap-6 text-sm text-muted">
        <a
          href={cadence.url}
          target="_blank"
          rel="noopener"
          class="hover:text-fg transition-colors duration-200"
        >
          Cadence ↗
        </a>
        <a
          href={social.instagram}
          target="_blank"
          rel="noopener"
          class="hover:text-fg transition-colors duration-200"
        >
          Instagram ↗
        </a>
        <a
          href={`mailto:${social.email}`}
          class="hover:text-fg transition-colors duration-200"
        >
          Email
        </a>
      </nav>
    </div>
  </div>
</footer>
