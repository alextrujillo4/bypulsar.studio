---
// Body-wide ambient light layer.
//
// Two effects, same stacking layer (z-index: -1, sits above body bg
// but below content cards thanks to body's `isolation: isolate`):
//
//  1. CursorGlow — soft halo that follows the pointer with a heartbeat
//     pulse. Hue locked to a cool 200°–260° arc (cyan→violet) so it
//     never warms into cream territory. Visible only on devices with
//     a hovering pointer (i.e. desktop).
//
//  2. ClickPulse — on every click/tap, spawn an ephemeral ripple at
//     the touch point that expands and fades over 1 second. This is
//     primarily for mobile (where there's no cursor to follow) but
//     also fires on desktop clicks.
---

<div id="cursor-glow" aria-hidden="true"></div>
<div id="click-pulse-layer" aria-hidden="true"></div>

<style is:global>
  /* is:global is required: .click-pulse spans are created by JS at
     runtime, so they don't carry Astro's scope attribute. Without
     is:global, the class rule + keyframes would compile to
     `.click-pulse[data-astro-cid-XXX]` and the JS-created span would
     never match. The cursor-glow + click-pulse-layer ids are unique
     so global scope is safe for them too. */
  #cursor-glow {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      calc(var(--cg-radius, 560) * 1px) circle
        at var(--cg-x, 50%) var(--cg-y, 50%),
      hsla(
        var(--cg-hue, 230),
        90%,
        70%,
        calc(var(--cg-intensity, 0.5) * 0.28)
      ) 0%,
      hsla(
        var(--cg-hue, 230),
        90%,
        65%,
        calc(var(--cg-intensity, 0.5) * 0.10)
      ) 25%,
      hsla(
        var(--cg-hue, 230),
        90%,
        60%,
        calc(var(--cg-intensity, 0.5) * 0.03)
      ) 45%,
      transparent 65%
    );
  }

  /* Hide the persistent cursor halo on touch-only devices — they
     can't hover, so a stuck halo at last-touch position looks broken.
     ClickPulse still works on touch. */
  @media (hover: none) and (pointer: coarse) {
    #cursor-glow {
      display: none;
    }
  }

  /* Layer where ephemeral click pulses live. Same stacking depth
     as cursor-glow so cards block them too. */
  #click-pulse-layer {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .click-pulse {
    position: absolute;
    width: 0;
    height: 0;
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%);
    background: radial-gradient(
      circle,
      hsla(230, 90%, 70%, 0.5) 0%,
      hsla(230, 90%, 65%, 0.15) 35%,
      transparent 70%
    );
    animation: click-pulse 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes click-pulse {
    0% {
      width: 80px;
      height: 80px;
      opacity: 1;
    }
    100% {
      width: 720px;
      height: 720px;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #cursor-glow,
    #click-pulse-layer {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const root = document.documentElement;
    const pulseLayer = document.getElementById("click-pulse-layer");

    /* ─── Cursor glow loop ───────────────────────────────────── */
    let tx = window.innerWidth / 2;
    let ty = window.innerHeight / 2;
    let cx = tx, cy = ty;
    let intensity = 0.6;
    let lastMove = Date.now() - 5000;
    let huePhase = 0;
    let phase = 0;

    document.addEventListener("mousemove", (e) => {
      tx = e.clientX;
      ty = e.clientY;
      lastMove = Date.now();
      intensity = Math.min(intensity + 0.12, 1);
    });

    function loop() {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;

      huePhase += 0.005;
      const hue = 230 + Math.sin(huePhase) * 30;

      phase += 0.018;
      const beat = (Math.sin(phase) + 1) * 0.5;

      const idle = Date.now() - lastMove;
      if (idle > 120) intensity = Math.max(intensity * 0.97, 0.45);

      const visualIntensity = (intensity * 0.7) + (beat * 0.3 * intensity);
      const radius = 540 + beat * 160;

      root.style.setProperty("--cg-x", cx.toFixed(0) + "px");
      root.style.setProperty("--cg-y", cy.toFixed(0) + "px");
      root.style.setProperty("--cg-hue", hue.toFixed(0));
      root.style.setProperty("--cg-intensity", visualIntensity.toFixed(3));
      root.style.setProperty("--cg-radius", radius.toFixed(0));

      requestAnimationFrame(loop);
    }
    loop();

    /* ─── Click pulse ────────────────────────────────────────── */
    function spawnPulse(x, y) {
      if (!pulseLayer) return;
      const el = document.createElement("span");
      el.className = "click-pulse";
      el.style.left = x + "px";
      el.style.top = y + "px";
      pulseLayer.appendChild(el);
      // Auto-remove after the animation completes (1s + small buffer)
      window.setTimeout(() => el.remove(), 1100);
    }

    // pointerdown covers both mouse click + touch tap; primary button only.
    document.addEventListener("pointerdown", (e) => {
      if (e.pointerType === "mouse" && e.button !== 0) return;
      spawnPulse(e.clientX, e.clientY);
    });
  })();
</script>
