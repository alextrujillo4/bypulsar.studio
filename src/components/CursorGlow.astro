---
// Body-wide cursor-following soft light. Sits at z-index -1 so cards
// cover it (only visible where the body bg is exposed: Intro section,
// Footer, gaps between cards).
//
// Visual signature:
//  - Hue locked to a cool range (200°–260° — blue → violet) so the
//    glow never warms into yellow/orange and tints the bg cream.
//  - Position lerped on mousemove (smooth follow)
//  - Intensity boosts on cursor movement, decays when idle
//  - Constant heartbeat pulse on the radius keeps it alive even
//    when the cursor is still
---

<div id="cursor-glow" aria-hidden="true"></div>

<style>
  #cursor-glow {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(
      calc(var(--cg-radius, 560) * 1px) circle
        at var(--cg-x, 50%) var(--cg-y, 50%),
      hsla(
        var(--cg-hue, 230),
        90%,
        70%,
        calc(var(--cg-intensity, 0.5) * 0.28)
      ) 0%,
      hsla(
        var(--cg-hue, 230),
        90%,
        65%,
        calc(var(--cg-intensity, 0.5) * 0.10)
      ) 25%,
      hsla(
        var(--cg-hue, 230),
        90%,
        60%,
        calc(var(--cg-intensity, 0.5) * 0.03)
      ) 45%,
      transparent 65%
    );
  }

  @media (prefers-reduced-motion: reduce) {
    #cursor-glow {
      display: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
    const root = document.documentElement;

    let tx = window.innerWidth / 2;
    let ty = window.innerHeight / 2;
    let cx = tx;
    let cy = ty;

    let intensity = 0.6;       // 0..1, decays over time, boosted on move
    let lastMove = Date.now() - 5000;
    let huePhase = 0;          // drives a sin oscillation between 200 and 260
    let phase = 0;             // heartbeat phase

    document.addEventListener("mousemove", (e) => {
      tx = e.clientX;
      ty = e.clientY;
      lastMove = Date.now();
      intensity = Math.min(intensity + 0.12, 1);
    });

    function loop() {
      // Smooth position lerp
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;

      // Hue oscillates between 200 (cyan-ish) and 260 (violet) —
      // never crosses into warm yellow/orange/red territory
      huePhase += 0.005;
      const hue = 230 + Math.sin(huePhase) * 30;

      // Heartbeat — sin oscillation between 0 and 1, period ~3s
      phase += 0.018;
      const beat = (Math.sin(phase) + 1) * 0.5;

      const idle = Date.now() - lastMove;
      if (idle > 120) intensity = Math.max(intensity * 0.97, 0.45);

      const visualIntensity = (intensity * 0.7) + (beat * 0.3 * intensity);
      const radius = 540 + beat * 160;

      root.style.setProperty("--cg-x", cx.toFixed(0) + "px");
      root.style.setProperty("--cg-y", cy.toFixed(0) + "px");
      root.style.setProperty("--cg-hue", hue.toFixed(0));
      root.style.setProperty("--cg-intensity", visualIntensity.toFixed(3));
      root.style.setProperty("--cg-radius", radius.toFixed(0));

      requestAnimationFrame(loop);
    }
    loop();
  })();
</script>
