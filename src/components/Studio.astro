---
import { team } from "../config";
---

<section id="studio" class="border-t border-line">
  <div class="mx-auto max-w-[1440px] px-6 md:px-10 lg:px-16 py-24 md:py-40">
    <p class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-12">
      01 / Studio
    </p>

    <h2 class="font-display font-extrabold tracking-tightest leading-[1] text-[clamp(40px,6vw,80px)] max-w-4xl mb-20">
      Somos dos.
      <br />
      Una constructora
      <br />
      <span class="italic font-light">y una directora creativa.</span>
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
      {team.map((member) => (
        <article class="group rounded-2xl bg-card border border-line p-8 md:p-10 hover:bg-line transition-colors duration-300">
          <div class="aspect-square mb-8 rounded-xl bg-bg border border-line flex items-center justify-center overflow-hidden">
            {/* TODO: replace with real photo of {member.name} */}
            <span
              class="font-display font-extrabold text-[clamp(64px,10vw,140px)] tracking-tightest text-muted group-hover:text-fg transition-colors duration-500"
            >
              {member.initials}
            </span>
          </div>
          <p class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-3">
            {member.role}
          </p>
          <h3 class="font-display font-bold text-2xl md:text-3xl mb-4 tracking-tight">
            {member.name}
          </h3>
          <p class="text-muted leading-relaxed">{member.bio}</p>
        </article>
      ))}
    </div>
  </div>
</section>
