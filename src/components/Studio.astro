---
import { team, social } from "../config";
---

<section id="team" class="ds-section-card-wrap">
  <div class="ds-white-card">
    <div class="ds-white-card-inner studio-grid">
      {/* LEFT — eyebrow, title, mission, CTA */}
      <div class="studio-text">
        <p class="studio-eyebrow" data-i18n="studio.eyebrow">the team</p>

        <h2 class="studio-title">
          <span class="studio-title-bright" data-i18n="studio.title.bright">two of us.</span>{" "}
          <span class="studio-title-fade" data-i18n="studio.title.fade">one signal — engineering and creative direction tuned to the same frequency.</span>
        </h2>

        <div class="studio-plus-row" aria-hidden="true">
          <span class="ds-plus studio-plus-mark">+</span>
          <span class="ds-plus studio-plus-mark">+</span>
        </div>

        <div class="studio-mission">
          <p class="studio-mission-title" data-i18n="studio.mission.title">Let's tune in</p>
          <p class="studio-mission-body" data-i18n="studio.mission.body">
            If your brand has signal, we'll amplify it. Small team, full bandwidth — no handoffs, no middle layer.
          </p>
          <a href={social.calendly} target="_blank" rel="noopener" class="studio-cta">
            <span data-i18n="studio.mission.cta">Book a call</span>
            <span class="studio-cta-dot" aria-hidden="true"></span>
          </a>
        </div>
      </div>

      {/* RIGHT — team cards */}
      <div class="studio-team">
        {team.map((member) => (
          <article class="team-card">
            <span class="team-card-plus" aria-hidden="true">+</span>
            <div class="team-card-meta">
              <p data-i18n={`studio.team.${member.i18nKey}.role`}>{member.role}</p>
              <p class="team-card-meta-sub" data-i18n="studio.team.atPulsar">at pulsar</p>
            </div>
            <div class="team-card-watermark" aria-hidden="true">
              {member.initials}
            </div>
            <h3 class="team-card-name">{member.name}</h3>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* ─── Grid ───────────────────────────────────────────── */
  .studio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 1024px) {
    .studio-grid {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      gap: 3rem;
      align-items: stretch;
    }
  }

  /* ─── LEFT column ─────────────────────────────────────── */
  .studio-text {
    display: flex;
    flex-direction: column;
  }

  .studio-eyebrow {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: #7a7a7a;
    margin: 0 0 2rem 0;
    text-transform: uppercase;
  }

  .studio-title {
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(40px, 5.5vw, 88px);
    letter-spacing: -0.03em;
    line-height: 1.05;
  }

  .studio-title-bright {
    color: #0a0a0a;
  }

  .studio-title-fade {
    color: #7a7a7a;
  }

  .studio-plus-row {
    display: flex;
    gap: clamp(2rem, 6vw, 6rem);
    margin: 3rem 0 4rem 0;
  }

  .studio-plus-mark {
    color: rgba(10, 10, 10, 0.25);
  }

  .studio-mission {
    margin-top: auto;
    max-width: 28rem;
  }

  .studio-mission-title {
    font-weight: 700;
    font-size: clamp(16px, 1.4vw, 19px);
    color: #0a0a0a;
    margin: 0 0 0.5rem 0;
  }

  .studio-mission-body {
    color: #7a7a7a;
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 1.5rem 0;
    max-width: 24rem;
  }

  .studio-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #0a0a0a;
    color: #f5f5f5;
    border-radius: 999px;
    padding: 0.7rem 0.7rem 0.7rem 1.25rem;
    font-size: 14px;
    font-weight: 500;
    transition: background-color 0.2s ease;
  }

  .studio-cta:hover {
    background: #1f1f1f;
  }

  .studio-cta-dot {
    display: inline-block;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #f5f5f5;
  }

  /* ─── RIGHT column — team cards ───────────────────────── */
  .studio-team {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .studio-team {
      gap: 1rem;
    }
  }

  .team-card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #2a2a2a 0%, #0a0a0a 100%);
    border-radius: clamp(14px, 2vw, 24px);
    aspect-ratio: 3 / 4;
    color: #f5f5f5;
    padding: clamp(0.75rem, 2vw, 1.25rem);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .team-card-plus {
    position: absolute;
    top: clamp(0.6rem, 1.5vw, 1rem);
    left: clamp(0.6rem, 1.5vw, 1rem);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(20px, 2vw, 26px);
    height: clamp(20px, 2vw, 26px);
    border-radius: 50%;
    background: #f5f5f5;
    color: #0a0a0a;
    font-size: clamp(11px, 1.1vw, 14px);
    font-weight: 600;
    line-height: 1;
  }

  .team-card-meta {
    position: absolute;
    top: clamp(0.6rem, 1.5vw, 1rem);
    right: clamp(0.6rem, 1.5vw, 1rem);
    z-index: 2;
    text-align: right;
    font-family: "Inter", system-ui, sans-serif;
    font-size: clamp(10px, 1vw, 14px);
    font-weight: 600;
    line-height: 1.2;
  }

  .team-card-meta p {
    margin: 0;
  }

  .team-card-meta-sub {
    color: rgba(245, 245, 245, 0.6);
    font-weight: 400;
  }

  .team-card-watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(72px, 12vw, 180px);
    letter-spacing: -0.06em;
    color: rgba(245, 245, 245, 0.12);
    pointer-events: none;
  }

  .team-card-name {
    position: relative;
    z-index: 2;
    margin: 0;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(22px, 2.4vw, 32px);
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: #f5f5f5;
  }
</style>
