---
import { cadence } from "../config";

const features = [
  "Multi-tenant",
  "Events",
  "Gallery",
  "Store",
  "Cadence AI",
];
---

<section id="cadence" class="ds-section-card-wrap">
  <div class="ds-ink-card cadence-card">
    <div class="ds-ink-card-inner cadence-grid">
      <div class="cadence-text">
        <p class="cadence-eyebrow">
          <span class="cadence-eyebrow-mark" aria-hidden="true">+</span>
          our SaaS
        </p>

        <h2 class="cadence-title">cadence.</h2>

        <p class="cadence-lead">
          Our SaaS for active communities. A professional site you run by chat —
          no CMS, no panels.
        </p>

        <ul class="cadence-features">
          {features.map((f) => (
            <li class="cadence-feature">{f}</li>
          ))}
        </ul>

        <a
          href={cadence.url}
          target="_blank"
          rel="noopener"
          class="cadence-cta"
        >
          Visit cadence.club
          <span aria-hidden="true">↗</span>
        </a>
      </div>

      <div class="cadence-visual" aria-hidden="true">
        <div class="cadence-visual-inner">
          <span class="cadence-visual-mark">C</span>
          <span class="cadence-visual-frequency"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cadence-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .cadence-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  /* ─── Text column ────────────────────────────────────── */
  .cadence-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 500;
    font-size: 14px;
    color: #f5f5f5;
    margin: 0 0 2rem 0;
  }

  .cadence-eyebrow-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #f5f5f5;
    color: #0a0a0a;
    font-size: 14px;
    font-weight: 600;
    line-height: 1;
  }

  .cadence-title {
    margin: 0 0 1.5rem 0;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(56px, 9vw, 140px);
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: #f5f5f5;
  }

  .cadence-lead {
    margin: 0 0 2rem 0;
    max-width: 32rem;
    font-size: clamp(15px, 1.1vw, 17px);
    color: #9a9a9a;
    line-height: 1.55;
  }

  .cadence-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2.5rem 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cadence-feature {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(245, 245, 245, 0.12);
    background: rgba(245, 245, 245, 0.04);
    color: #f5f5f5;
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    font-size: 13px;
    font-weight: 500;
  }

  .cadence-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #f5f5f5;
    color: #0a0a0a;
    border-radius: 999px;
    padding: 0.85rem 1.5rem;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: transform 0.2s ease, background 0.2s ease;
  }

  .cadence-cta:hover {
    transform: translateY(-1px);
    background: #ffffff;
  }

  /* ─── Visual column ──────────────────────────────────── */
  .cadence-visual {
    position: relative;
    aspect-ratio: 1.1 / 1;
    border-radius: clamp(16px, 2vw, 24px);
    background:
      radial-gradient(60% 60% at 50% 50%, rgba(80, 150, 255, 0.18), transparent 70%),
      linear-gradient(135deg, #1a1a1a, #0a0a0a);
    border: 1px solid rgba(245, 245, 245, 0.08);
    overflow: hidden;
    isolation: isolate;
  }

  .cadence-visual-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cadence-visual-mark {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(160px, 20vw, 280px);
    letter-spacing: -0.06em;
    color: rgba(245, 245, 245, 0.95);
    line-height: 1;
    text-transform: lowercase;
  }

  .cadence-visual-frequency {
    position: absolute;
    inset: 50% -50% auto auto;
    width: 200%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(80, 150, 255, 0.3) 40%,
      rgba(80, 150, 255, 0.6) 50%,
      rgba(80, 150, 255, 0.3) 60%,
      transparent 100%
    );
    transform: translateY(-50%);
  }
</style>
