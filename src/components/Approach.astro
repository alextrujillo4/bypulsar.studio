---
import { approach } from "../config";
---

<section id="approach" class="border-t border-line">
  <div class="mx-auto max-w-[1440px] px-6 md:px-10 lg:px-16 py-24 md:py-40">
    <p class="font-mono text-xs tracking-[0.2em] uppercase text-muted mb-12">
      03 / Approach
    </p>

    <h2 class="font-display font-extrabold tracking-tightest leading-[1] text-[clamp(40px,6vw,80px)] max-w-4xl mb-20">
      Cómo trabajamos
    </h2>

    <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {approach.map((step) => (
        <li class="border-t border-line pt-8">
          <span class="font-mono text-xs tracking-[0.2em] uppercase text-muted block mb-6">
            {step.step}
          </span>
          <h3 class="font-display font-bold text-2xl md:text-3xl tracking-tight mb-4">
            {step.title}
          </h3>
          <p class="text-muted leading-relaxed">{step.desc}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
