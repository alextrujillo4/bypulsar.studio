---
const letters = ["p", "u", "l", "s", "a", "r"];
---

<div id="intro" class="intro" aria-hidden="true">
  <div class="intro-logo">
    {letters.map((l, i) => (
      <span style={`--i:${i}`}>{l}</span>
    ))}
    <span class="intro-reg" style="--i:6">®</span>
  </div>
</div>

<style>
  .intro {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: intro-out 0.8s 3.3s cubic-bezier(0.76, 0, 0.24, 1) forwards;
    will-change: transform;
  }

  .intro-logo {
    display: flex;
    align-items: baseline;
    overflow: hidden;
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 800;
    font-size: clamp(72px, 14vw, 200px);
    letter-spacing: -0.06em;
    color: #f5f5f5;
    line-height: 1;
  }

  .intro-logo span {
    display: inline-block;
    transform: translateY(110%);
    opacity: 0;
    animation:
      letter-in 0.5s ease-out forwards calc(var(--i) * 0.1s),
      letter-out 0.5s ease-in forwards calc(2.5s + var(--i) * 0.05s);
    will-change: transform, opacity;
  }

  .intro-reg {
    font-size: 0.4em;
    align-self: flex-start;
    margin-left: 0.05em;
  }

  @keyframes letter-in {
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes letter-out {
    to {
      transform: translateY(-110%);
      opacity: 0;
    }
  }

  @keyframes intro-out {
    to {
      transform: translateY(-100%);
    }
  }

  :global(.intro-skip) .intro {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .intro {
      display: none;
    }
  }
</style>
