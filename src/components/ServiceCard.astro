---
import type { Service } from "../config";

interface Props {
  service: Service;
}

const { service } = Astro.props;
const isExternal = !!service.external;
const Tag = isExternal ? "a" : "div";
const linkProps = isExternal
  ? { href: service.external, target: "_blank", rel: "noopener" }
  : {};
---

<Tag
  {...linkProps}
  class:list={[
    "service-card group block rounded-2xl border border-line bg-card p-8 md:p-10 transition-colors duration-300",
    isExternal ? "hover:bg-fg hover:text-bg cursor-pointer" : "hover:bg-line",
  ]}
>
  <div class="flex items-start justify-between mb-8">
    <span class="font-mono text-xs tracking-[0.2em] uppercase text-muted group-hover:text-bg/60 transition-colors duration-300">
      {service.num}
    </span>
    {isExternal && (
      <span
        class="text-muted group-hover:text-bg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300"
        aria-hidden="true"
      >
        ↗
      </span>
    )}
  </div>

  <h3 class="font-display font-bold text-2xl md:text-3xl tracking-tight mb-3">
    {service.title}
  </h3>
  <p class="text-muted group-hover:text-bg/70 leading-relaxed mb-8 transition-colors duration-300">
    {service.lead}
  </p>

  <ul class="space-y-2 text-sm">
    {service.bullets.map((bullet) => (
      <li class="flex items-start gap-3 text-muted group-hover:text-bg/80 transition-colors duration-300">
        <span class="mt-2 inline-block h-px w-4 bg-current opacity-50"></span>
        <span>{bullet}</span>
      </li>
    ))}
  </ul>
</Tag>
