---
import type { Service } from "../config";

interface Props {
  service: Service;
}

const { service } = Astro.props;
const isExternal = !!service.external;
const Tag = isExternal ? "a" : "div";
const linkProps = isExternal
  ? { href: service.external, target: "_blank", rel: "noopener" }
  : {};
---

<Tag
  {...linkProps}
  class:list={["group block", isExternal ? "ds-card-invert" : "ds-card-hover"]}
>
  <div class="flex items-start justify-between mb-8">
    <span class="ds-label transition-colors duration-300">
      {service.num}
    </span>
    {isExternal && (
      <span
        class="text-muted group-hover:text-bg group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all duration-300"
        aria-hidden="true"
      >
        ↗
      </span>
    )}
  </div>

  <h3 class="ds-heading-sub mb-3 lowercase">
    {service.title.toLowerCase()}
  </h3>
  <p class="text-muted group-hover:text-bg/80 leading-relaxed mb-8 transition-colors duration-300">
    {service.lead}
  </p>

  <ul class="space-y-2 text-sm">
    {service.bullets.map((bullet) => (
      <li class="flex items-start gap-3 text-muted group-hover:text-bg/80 transition-colors duration-300">
        <span class="mt-2 inline-block h-px w-4 bg-current opacity-50"></span>
        <span>{bullet}</span>
      </li>
    ))}
  </ul>
</Tag>
